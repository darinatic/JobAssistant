# Copy to frontend/.env (gitignored). All VITE_* vars are exposed to the
# browser — never put a service-role / secret key here.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# sb_publishable_* (preferred) or the legacy anon JWT.
VITE_SUPABASE_ANON_KEY=

# FastAPI backend base URL (no trailing slash).
VITE_API_URL=http://127.0.0.1:8000
