# ResumeAgent — Environment Configuration
# Copy to .env and fill in. The app is stateless: no database, no auth.

# =============================================================================
# LLM Provider (required) — JD parsing + resume/cover-letter tailoring
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-api...

# =============================================================================
# Job search defaults (optional) — used by the scrapers
# =============================================================================
LINKEDIN_SEARCH_KEYWORD=AI Engineer
LINKEDIN_SEARCH_LOCATION=Singapore

# =============================================================================
# Learned fit predictor (optional) — ranks search results by CV↔JD fit
# =============================================================================
# OFF by default (MATCH_PREDICTOR_MODEL=none) → results rank by lexical relevance.
# To enable, set the model flag AND point at a trained artifact (model.onnx +
# tokenizer.json), either a local dir or a HuggingFace repo. Needs the `[predictor]`
# extra (onnxruntime). Scores are compressed but discriminate — used to RANK, and
# surfaced in the UI as a relative Strong/Moderate/Weak + top-fit marker, not a %.
# MATCH_PREDICTOR_MODEL=v1
# MATCH_PREDICTOR_PATH=/path/to/artifact-dir      # local model.onnx + tokenizer.json
# MATCH_PREDICTOR_REPO=your-org/resume-fit-onnx   # or a HuggingFace Hub repo id
# HF_TOKEN=hf_...                                 # only if the repo is private

# =============================================================================
# LangSmith observability (optional) — LLM tracing + Hub prompt versioning
# =============================================================================
# OFF by default. When enabled, LangChain LLM calls trace to LangSmith (no code
# changes). Prompt inputs/outputs (CV/JD text) are REDACTED by default to keep the
# app's no-storage stance — set LANGSMITH_HIDE_IO=false locally to see payloads.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_PROJECT=resumeagent
# LANGSMITH_HIDE_IO=true
# Optional — pull prompts from the LangSmith Hub playground at runtime (else the
# in-repo registry serves). Seed the Hub via scripts/push_prompts_to_langsmith.py.
# LANGSMITH_PROMPT_REFS=resume_tailor=me/resume_tailor,jd_parser=me/jd_parser

# =============================================================================
# Browserbase (optional) — cloud browser for reliable LinkedIn descriptions
# =============================================================================
# When both are set, LinkedIn descriptions are fetched via a Browserbase cloud
# browser (dodges the guest IP soft-wall). Leave blank to use the free httpx path.
# BROWSERBASE_API_KEY=bb_...
# BROWSERBASE_PROJECT_ID=...
# BROWSERBASE_REGION=ap-southeast-1
# Residential proxies need a PAID plan (free plan → 402); the cloud browser works
# without them, so this stays off by default.
# BROWSERBASE_PROXIES=false
# Route the JobStreet scraper through Browserbase too (survives datacenter IPs in
# production). Off locally (uses in-container Chromium); set true when deployed.
# BROWSERBASE_SCRAPERS=false

# =============================================================================
# Rate limiting (public demo cost control) — per client IP; 0 disables
# =============================================================================
# RATE_LIMIT_PER_MIN=12
# RATE_LIMIT_PER_DAY=120

# =============================================================================
# API / Frontend
# =============================================================================
# Comma-separated origins allowed to call the FastAPI backend.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# Tectonic (LaTeX PDF renderer) is a runtime binary. The server checks PATH + common
# install locations; set TECTONIC_PATH only if it lives somewhere unusual.
# Install: `cargo install tectonic` / `scoop install tectonic` / GitHub release.
# TECTONIC_PATH=C:\Users\you\AppData\Local\tectonic\tectonic.exe
